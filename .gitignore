# is intentionally NOT ignored.
.env
.env.*
!.env.example
*.env
.r2-build.env

# ── Local AI / vault / user data ──────────────────────────────────────────
# User-owned local data, never source.
R2Vault/
R2Obsidian/
*.db
*.db-journal
*.db-wal
*.db-shm

# ── Internal / private project notes ──────────────────────────────────────
# CLAUDE.md is the project's internal instruction file — do not publish.
CLAUDE.md
.claude/
.cursor/
.aider*

# ── Logs ──────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ── Editor / OS junk ──────────────────────────────────────────────────────
