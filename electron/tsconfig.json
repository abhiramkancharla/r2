{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "../dist/electron",
    "rootDir": ".",
    "sourceMap": true
  },
  "include": ["**/*.ts"],
  "exclude": ["../node_modules", "../dist", "../renderer"]
}
